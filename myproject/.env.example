# UTAMEMO 環境変数設定例
# このファイルを .env にコピーして、実際の値を設定してください

# ========================================
# 必須設定（本番環境）
# ========================================

# Django秘密鍵 - 本番環境では必須
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# 許可するホスト（カンマ区切り）
# 例: example.com,www.example.com,api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# デバッグモード（本番環境ではFalse）
DEBUG=False

# 本番環境フラグ
PRODUCTION=false

# ========================================
# AI API設定
# ========================================

# Google Gemini API (OCR + 歌詞生成)
GEMINI_API_KEY=your-gemini-api-key

# Mureka API (楽曲生成)
MUREKA_API_KEY=your-mureka-api-key
USE_MUREKA_API=true
MUREKA_API_URL=https://platform.mureka.ai

# ローカルLLM歌詞生成 (Geminiの代わりに学校GPUで歌詞生成)
# LYRICS_BACKEND: gemini / cloud / local / auto
LYRICS_BACKEND=gemini
LOCAL_LLM_URL=http://localhost:8000
LOCAL_LLM_API_KEY=your-local-llm-api-key
LOCAL_LLM_TIMEOUT=60

# クラウドLLM歌詞生成 (OpenAI互換: Together AI / Fireworks AI / Groq / OpenRouter)
# CLOUD_LLM_PROVIDER: together / fireworks / groq / openrouter
# CLOUD_LLM_URL を空にするとプロバイダー別デフォルトURL自動選択
# CLOUD_LLM_MODEL を空にするとプロバイダー別デフォルトモデル自動選択
#
# 例: Together AI で Llama 3 8B を使う場合
#   CLOUD_LLM_PROVIDER=together
#   CLOUD_LLM_API_KEY=your-together-api-key
#   → URL/モデルは自動設定される
#
# 例: Groq (高速) を使う場合
#   CLOUD_LLM_PROVIDER=groq
#   CLOUD_LLM_API_KEY=your-groq-api-key
CLOUD_LLM_PROVIDER=
CLOUD_LLM_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_TIMEOUT=90

# ========================================
# データベース設定（本番環境用）
# ========================================

# PostgreSQL URL（Render等で使用）
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ========================================
# ファイルアップロード制限
# ========================================

# 画像ファイルの最大サイズ（バイト、デフォルト10MB）
MAX_IMAGE_SIZE=10485760

# PDFファイルの最大サイズ（バイト、デフォルト25MB）
MAX_PDF_SIZE=26214400

# 歌詞の最大文字数
MAX_LYRICS_LENGTH=5000

# 歌詞の最小文字数
MIN_LYRICS_LENGTH=50

# ========================================
# キューワーカー設定
# ========================================

# 最大リトライ回数
MAX_GENERATION_RETRIES=3

# リトライ間隔の基本秒数（実際の待機時間は base * retry_count）
RETRY_BACKOFF_BASE=30

# バックグラウンドキューワーカーを無効化
# 本番環境で複数ワーカーを使用する場合は、1つのプロセスでのみ有効化
DISABLE_QUEUE_WORKER=false

# ========================================
# メール設定（パスワードリセット等）
# ========================================

# SMTPバックエンド（本番環境では必須）
# 開発環境でコンソール出力のみにする場合:
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=UTAMEMO <your-email@gmail.com>

# ========================================
# Render固有設定
# ========================================

# Renderがデプロイ時に自動設定
# RENDER=true
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
